NODE_ENV=
PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret

SQLITE_DB_FILE=
SQLITE_BUSY_TIMEOUT_MS=5000
JSON_BODY_LIMIT=12mb

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

UPLOADTHING_SECRET=
UPLOADTHING_TOKEN=

MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_MOCK_SUCCESS=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Future production support. When both are set, the Twilio client uses these instead of the auth token for API calls.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

TWILIO_SMS_FROM=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WHATSAPP_FROM=
TWILIO_VERIFY_SERVICE_SID=

MESSAGING_PROVIDER=twilio
MESSAGING_DEFAULT_CHANNEL=whatsapp

ENABLE_SMS=true
ENABLE_WHATSAPP=true
ENABLE_VERIFY=true
ENABLE_MESSAGE_LOGS=true

TWILIO_STATUS_CALLBACK=
TWILIO_VALIDATE_STATUS_CALLBACK=true

MESSAGING_REQUIRE_CONFIG=
MESSAGING_DRY_RUN=
MESSAGE_QUEUE_PROVIDER=memory
MESSAGE_QUEUE_NAME=omanutro-messaging
MESSAGE_QUEUE_ATTEMPTS=5
MESSAGE_QUEUE_RETRY_DELAY_MS=30000
REDIS_URL=
